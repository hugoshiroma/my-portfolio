rCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"82"},{"filePath":"132","messages":"133","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"82"},{"filePath":"134","messages":"135","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"136","messages":"137","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"82"},{"filePath":"138","messages":"139","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"82"},"C:\\Projetos\\my-portfolio\\src\\App.js",[],"C:\\Projetos\\my-portfolio\\src\\reportWebVitals.js",[],["140","141"],"C:\\Projetos\\my-portfolio\\src\\assets\\assets-urls.enum.js",[],["142","143"],"C:\\Projetos\\my-portfolio\\src\\animations\\background-image.animation.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\title.animation.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\description.animation.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\panel.animation.js",[],["144","145"],"C:\\Projetos\\my-portfolio\\src\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\header.animation.js",[],["146","147"],"C:\\Projetos\\my-portfolio\\src\\components\\panel\\index.js",["148"],"import React, { useRef, useEffect } from \"react\";\r\nimport { FontAwesomeIcon } from \"@fortawesome/react-fontawesome\";\r\n\r\nimport { panelAnimation } from \"animations/panel.animation\";\r\nimport { titleAnimation } from \"animations/title.animation\";\r\nimport { descriptionAnimation } from \"animations/description.animation\";\r\nimport { personalPhoto } from \"assets/assets-urls.enum\";\r\n\r\nimport \"./style.scss\";\r\n\r\nconst defaultValues = {\r\n  panelAnimationDirInverted: false,\r\n};\r\n\r\nconst Panel = ({ type, animations }) => {\r\n  const { panelAnimationDirInverted } = animations\r\n    ? { ...animations }\r\n    : defaultValues;\r\n  let introPanel = useRef();\r\n  let introContainer = useRef();\r\n  let introDescription = useRef();\r\n\r\n  const animateByType = () => {\r\n    switch (type) {\r\n      case \"personal-info\":\r\n        titleAnimation(introContainer);\r\n        break;\r\n      case \"list\":\r\n        descriptionAnimation(introDescription);\r\n        break;\r\n      default:\r\n        break;\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    panelAnimation(introPanel, panelAnimationDirInverted);\r\n    animateByType();\r\n  }, [introPanel, introContainer, introDescription, panelAnimationDirInverted]);\r\n\r\n  const renderContent = () => {\r\n    switch (type) {\r\n      case \"personal-info\":\r\n        return (\r\n          <div\r\n            className=\"row\"\r\n            ref={(el) => {\r\n              introContainer = el;\r\n            }}\r\n          >\r\n            <div className=\"main-img\">\r\n              <img src={personalPhoto} alt=\"myself :)\" />\r\n            </div>\r\n            <div className=\"row\" id=\"basic-info\">\r\n              <h2 className=\"title\">Hugo Gaio Shiroma</h2>\r\n              <br />\r\n              <div className=\"line\">\r\n                <FontAwesomeIcon icon=\"map-marker-alt\" />\r\n                <p className=\"subtitle\">Vila Carrão - São Paulo, SP</p>\r\n              </div>\r\n              <div className=\"line\">\r\n                <FontAwesomeIcon icon=\"phone-alt\" />\r\n                <p className=\"subtitle\">55 11 99673-1201</p>\r\n              </div>\r\n              <div className=\"line\">\r\n                <FontAwesomeIcon icon=\"heart\" />\r\n                <p className=\"subtitle\">Solteiro</p>\r\n              </div>\r\n              <div className=\"line\">\r\n                <FontAwesomeIcon icon=\"child\" />\r\n                <p className=\"subtitle\">24 anos</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        );\r\n      case \"list\":\r\n        return (\r\n          <div\r\n            className=\"subtitle\"\r\n            ref={(el) => {\r\n              introDescription = el;\r\n            }}\r\n          >\r\n            <ul>\r\n              <li>Engenheiro de software front-end</li>\r\n              <li>\r\n                <hr />\r\n                Apaixonado por designs modernos\r\n              </li>\r\n              <li>\r\n                <hr />\r\n                Entusiasta de padrões lógicos de UX/UI\r\n              </li>\r\n            </ul>\r\n          </div>\r\n        );\r\n      default:\r\n        return (\r\n          <div\r\n            className=\"row\"\r\n            ref={(el) => {\r\n              introContainer = el;\r\n            }}\r\n          >\r\n            Em construção\r\n          </div>\r\n        );\r\n    }\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <div\r\n        className=\"glass-panel\"\r\n        ref={(el) => {\r\n          introPanel = el;\r\n        }}\r\n      >\r\n        {renderContent()}\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Panel;","C:\\Projetos\\my-portfolio\\src\\pages\\projects\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\pages\\home\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\components\\header\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\pages\\experience\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\pages\\experience\\config.js",["149"],"import {\r\n  AOCgraduation,\r\n  AOCgraduation2,\r\n  AOCbus,\r\n  AOCtheater,\r\n} from \"assets/assets-urls.enum\";\r\n\r\nexport const experiences = [\r\n  {\r\n    job: \"Menor aprendiz\",\r\n    company: \"AOC International\",\r\n    startDate: \"Jul 2011\",\r\n    endDate: \"Jun 2013\",\r\n    description: (\r\n      <>\r\n        Aqui começa minha jornada frente ao mundo real! Com 14 anos, ainda no\r\n        ensino médio, tomei uma decisão que mudaria minha vida:\r\n        <strong>decidi que iria passar na melhor faculdade do país</strong>. Pra\r\n        isso, precisava juntar dinheiro para me sustentar durante meu período\r\n        acadêmico, então passei num processo seletivo para{\" \"}\r\n        <strong>\r\n          menor aprendiz na montadora oficial da AOC International\r\n        </strong>{\" \"}\r\n        em Jundiaí, responsável por produzir computadores, tablets, all-in-ones\r\n        e monitores. Neste processo, era um pré-requisito também{\" \"}\r\n        <strong>\r\n          passar na prova de CAI (Curso de Aprendizagem Industrial) do SENAI\r\n        </strong>\r\n        . Então, de 7h às 11h eu ficava na empresa adquirindo conhecimento\r\n        prático diretamente na{\" \"}\r\n        <strong>linha de produção/setor técnico/P&D</strong> ou adquirindo\r\n        conhecimento teórico através de{\" \"}\r\n        <strong>\r\n          palestras, dinâmicas e avaliações sobre temas corporativos/industriais\r\n          diversos\r\n        </strong>{\" \"}\r\n        tais como eletrônica básica, documentações industriais básicas (ITs,\r\n        mapas de placas, diagramas gerais de produtos), 5S, programação básica,\r\n        segurança patrimonial, comportamento empresarial, etc. Após isso, de\r\n        12h30 até 16h30 eu permanecia no SENAI pelo{\" \"}\r\n        <strong>curso de eletricista de manutenção</strong>. Por fim, de 19h às\r\n        22h45 eu permanecia na escola, seguindo esta mesma rotina durante 2\r\n        anos.\r\n      </>\r\n    ),\r\n    photos: [{ src: AOCbus }, { src: AOCtheater }, { src: AOCgraduation }],\r\n  },\r\n  {\r\n    job: \"Estagiário\",\r\n    company: \"Zellar\",\r\n    startDate: \"Mai 2018\",\r\n    endDate: \"Out 2019\",\r\n    description: (\r\n      <>\r\n        Em meu retorno ao mercado de trabalho após alguns anos dedicado aos\r\n        estudos, entrei em uma startup chamada Zellar. Sendo uma empresa de tecnologia incubada de outra empresa de prestação de serviços de portaria, segurança patrimonial e limpeza, atuávamos integralmente no produto da empresa que atendia pontualmente as necessidades de suas respectivas filiais espalhadas pelo Brasil\r\n      </>\r\n    ),\r\n  },\r\n  {\r\n    job: \"Desenvolvedor Jr.\",\r\n    company: \"Zellar\",\r\n    startDate: \"Out 2019\",\r\n    endDate: \"Dez 2019\",\r\n    description: \"\",\r\n    continuation: true,\r\n  },\r\n  {\r\n    job: \"Engenheiro de Software Jr.\",\r\n    company: \"Acesso\",\r\n    startDate: \"Dez 2019\",\r\n    endDate: \"Jan 2021\",\r\n    description: \"\",\r\n  },\r\n  {\r\n    job: \"Engenheiro de Software Pl.\",\r\n    company: \"Acesso\",\r\n    startDate: \"Abr 2021\",\r\n    endDate: \"atualmente\",\r\n    description: \"\",\r\n    continuation: true,\r\n  },\r\n];\r\n","C:\\Projetos\\my-portfolio\\src\\config.js",[],["150","151"],"C:\\Projetos\\my-portfolio\\src\\components\\photo\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\components\\gallery\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\contrast.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\size.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\fadeout.js",[],["152","153"],"C:\\Projetos\\my-portfolio\\src\\components\\timeline\\index.js",["154"],"C:\\Projetos\\my-portfolio\\src\\components\\index.js",[],["155","156"],"C:\\Projetos\\my-portfolio\\src\\components\\icons\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\utils\\helpers.js",["157"],"import { useEffect, useState } from \"react\";\r\n\r\nconst IsMobile = () => {\r\n  const [widthValue, setWidthValue] = useState(window.innerWidth);\r\n\r\n  const getWindowDimensions = () => {\r\n    const { innerWidth: width } = window;\r\n    return width;\r\n  };\r\n\r\n  useEffect(() => {\r\n    window.addEventListener(\"resize\", () =>\r\n      setWidthValue(getWindowDimensions())\r\n    );\r\n    return () =>\r\n      window.removeEventListener(\"resize\", () =>\r\n        setWidthValue(getWindowDimensions())\r\n      );\r\n  }, []);\r\n\r\n  return widthValue <= 480;\r\n};\r\n\r\nexport default {\r\n  isMobile: IsMobile,\r\n};\r\n","C:\\Projetos\\my-portfolio\\src\\utils\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\components\\button\\index.js",["158"],"C:\\Projetos\\my-portfolio\\src\\components\\sidebar\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\components\\overlay\\index.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\fadein.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\slidein.js",[],"C:\\Projetos\\my-portfolio\\src\\animations\\scrollto.js",[],{"ruleId":"159","replacedBy":"160"},{"ruleId":"161","replacedBy":"162"},{"ruleId":"159","replacedBy":"163"},{"ruleId":"161","replacedBy":"164"},{"ruleId":"159","replacedBy":"165"},{"ruleId":"161","replacedBy":"166"},{"ruleId":"159","replacedBy":"167"},{"ruleId":"161","replacedBy":"168"},{"ruleId":"169","severity":1,"message":"170","line":39,"column":6,"nodeType":"171","endLine":39,"endColumn":79,"suggestions":"172"},{"ruleId":"173","severity":1,"message":"174","line":3,"column":3,"nodeType":"175","messageId":"176","endLine":3,"endColumn":17},{"ruleId":"159","replacedBy":"177"},{"ruleId":"161","replacedBy":"178"},{"ruleId":"159","replacedBy":"179"},{"ruleId":"161","replacedBy":"180"},{"ruleId":"169","severity":1,"message":"170","line":72,"column":6,"nodeType":"171","endLine":72,"endColumn":75,"suggestions":"181"},{"ruleId":"159","replacedBy":"182"},{"ruleId":"161","replacedBy":"183"},{"ruleId":"184","severity":1,"message":"185","line":24,"column":1,"nodeType":"186","endLine":26,"endColumn":3},{"ruleId":"173","severity":1,"message":"187","line":3,"column":10,"nodeType":"175","messageId":"176","endLine":3,"endColumn":17},"no-native-reassign",["188"],"no-negated-in-lhs",["189"],["188"],["189"],["188"],["189"],["188"],["189"],"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'animateByType'. Either include it or remove the dependency array.","ArrayExpression",["190"],"no-unused-vars","'AOCgraduation2' is defined but never used.","Identifier","unusedVar",["188"],["189"],["188"],["189"],["191"],["188"],["189"],"import/no-anonymous-default-export",